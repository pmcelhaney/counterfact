---
import { getCollection, render } from "astro:content";
import DocLayout from "../../layouts/DocLayout.astro";

export async function getStaticPaths() {
  const docs = await getCollection("docs");
  const routes = [];
  for (const doc of docs) {
    // Serve at the clean URL (e.g. /docs/getting-started)
    routes.push({ params: { slug: doc.id }, props: { doc, isMdAlias: false } });
    // Also serve at the .md URL (e.g. /docs/getting-started.md) as a redirect
    // to the clean URL.  Without this, static pages served under the .md path
    // have a different base path (/docs/getting-started.md/) which breaks
    // all relative links inside the document.
    routes.push({
      params: { slug: `${doc.id}.md` },
      props: { doc, isMdAlias: true },
    });
  }
  return routes;
}

const { doc, isMdAlias } = Astro.props;

// Canonical URL always points to the clean (no .md) path.
const canonicalPath = `/docs/${doc.id}`;

// For .md alias pages, redirect to the clean URL so that relative links inside
// the rendered document always resolve against the clean base path.
if (isMdAlias) {
  return Astro.redirect(canonicalPath, 301);
}

const { Content, headings } = await render(doc);

const titleFromHeading = headings.find((h) => h.depth === 1)?.text;
const titleFromSlug = doc.id
  .split("/")
  .at(-1)!
  .replace(/-/g, " ")
  .replace(/\b\w/g, (c) => c.toUpperCase());
const title = titleFromHeading ?? titleFromSlug;
---

<DocLayout title={title} canonicalPath={canonicalPath}>
  <Content />
</DocLayout>
